generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pokemon {
  id             Int            @id @default(autoincrement())
  pokedexNumber  Int            @unique
  name           String         @unique
  description    String?        @db.Text
  height         Float
  weight         Float
  baseExperience Int?
  imageUrl       String?
  spriteUrl      String?
  isLegendary    Boolean        @default(false)
  isMythical     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  types          PokemonType[]
  abilities      PokemonAbility[]
  stats          PokemonStat[]

  @@map("pokemons")
}

model Type {
  id       Int           @id @default(autoincrement())
  name     String        @unique
  color    String?
  pokemons PokemonType[]

  @@map("types")
}

model PokemonType {
  pokemonId Int
  typeId    Int
  slot      Int @default(1)

  pokemon Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade)
  type    Type    @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@id([pokemonId, typeId])
  @@map("pokemon_types")
}

model Ability {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?          @db.Text
  pokemons    PokemonAbility[]

  @@map("abilities")
}

model PokemonAbility {
  pokemonId Int
  abilityId Int
  isHidden  Boolean @default(false)
  slot      Int     @default(1)

  pokemon Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade)
  ability Ability @relation(fields: [abilityId], references: [id], onDelete: Cascade)

  @@id([pokemonId, abilityId])
  @@map("pokemon_abilities")
}

model Stat {
  id       Int           @id @default(autoincrement())
  name     String        @unique
  pokemons PokemonStat[]

  @@map("stats")
}

model PokemonStat {
  pokemonId Int
  statId    Int
  baseStat  Int
  effort    Int @default(0)

  pokemon Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade)
  stat    Stat    @relation(fields: [statId], references: [id], onDelete: Cascade)

  @@id([pokemonId, statId])
  @@map("pokemon_stats")
}
